Algoritmo "reais para dolar melhorado"

Var
   R, D: real
   C, V: inteiro


Inicio
   Escreva("Quantas converçőes vocę quer? ")
   leia(V)
   C <- 1
   Enquanto (C <= V) faca
      Escreva("Quantos reais eu tenho? ")
      leia(R)
      D <- R / 5
      Escreval("Dinheiro convertido para dolar: ", D)
      C <- C + 1
   fimenquanto

Fimalgoritmo