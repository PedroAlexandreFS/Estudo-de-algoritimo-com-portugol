Algoritmo "contador de 0 ate onde o quiser"

Var

   contador, Numero: inteiro



Inicio
      Escreva("qual numero vocę quer? ")
      leia(Numero)
      contador <- 0
      Enquanto (contador <= Numero) faca
               Escreval(contador)
               contador <- contador + 1
      fimenquanto


Fimalgoritmo